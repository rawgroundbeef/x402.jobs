# Server
PORT=3011
NODE_ENV=development
PUBLIC_URL=http://localhost:3011

# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Solana
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Base
BASE_RPC_URL=https://mainnet.base.org
# Platform wallet to receive Base fees (EVM address)
# Jobputer's Base wallet for receiving platform fees
BASE_PLATFORM_WALLET=0xAEB58049d3C266D55595a596Fae249C10764a031

# Twitter / X (optional, required for X posting)
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret
# Override only if not using PUBLIC_URL + /integrations/x/oauth/callback
# TWITTER_CALLBACK_URL=https://your-api.example.com/integrations/x/oauth/callback

# CORS
CORS_ORIGIN=http://localhost:3010

# OpenAI (required for AI workflow builder)
OPENAI_API_KEY=your-openai-api-key

# Inngest (for production - not needed for local dev)
# INNGEST_EVENT_KEY=your-event-key
# INNGEST_SIGNING_KEY=signkey-xxx

# x402 Ecosystem Indexer (optional)
# HELIUS_API_KEY=your-helius-api-key
# HELIUS_WEBHOOK_SECRET=your-webhook-secret

# Platform Fee Configuration
# Fee as percentage of job resource cost (default 1.5% = 0.015)
PLATFORM_FEE_PERCENTAGE=0.015
# Minimum fee in USDC (default $0.01)
PLATFORM_FEE_MINIMUM=0.01

# $JOBS Rewards System
# Token mint address for $JOBS
JOBS_TOKEN_MINT=6cNcXWqYvK9nhD1TsjJ1ZH1KATXcaPaRJtZPHyVkJoBs
# Fee collection address (where platform fees accumulate) - Jobputer agent wallet
FEE_COLLECTION_ADDRESS=6Yw8BnPU6sadbsZtB6LykxTVfhj8qmEVL2cyjdh5ChKh
# Private key for fee collection wallet (base58 encoded) - required for reward payouts
# FEE_COLLECTION_PRIVATE_KEY=your-base58-encoded-private-key
# Treasury address for receiving 50% of fees (after first month) and unclaimed rewards
# TREASURY_ADDRESS=your-treasury-address

# Admin email whitelist for /api/admin/refunds — comma-separated, no spaces
# ADMIN_EMAILS=alice@example.com,bob@example.com
ADMIN_EMAILS=

# Admin user ID (auth.users.id UUID) to receive notifications when users
# request refunds. If unset, notifications are skipped silently.
# ADMIN_NOTIFICATIONS_USER_ID=00000000-0000-0000-0000-000000000000
ADMIN_NOTIFICATIONS_USER_ID=

