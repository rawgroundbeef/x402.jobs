{
  "name": "x402-jobs-api",
  "version": "1.0.0",
  "description": "API for x402.jobs - X402 workflow automation",
  "private": true,
  "scripts": {
    "dev": "concurrently --kill-others \"pnpm dev:api\" \"pnpm dev:inngest\"",
    "dev:api": "PORT=3011 nodemon --exec ts-node -r tsconfig-paths/register src/index.ts",
    "dev:inngest": "npx inngest-cli@latest dev -u http://localhost:3011/inngest -u http://localhost:3001/api/inngest --no-poll",
    "build": "tsup",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.57.0",
    "@openfacilitator/sdk": "^1.0.0",
    "@solana/spl-token": "^0.4.12",
    "@solana/web3.js": "^1.98.4",
    "@supabase/supabase-js": "^2.38.4",
    "axios": "^1.16.1",
    "bs58": "^5.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "ethers": "^6.15.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "inngest": "^3.46.0",
    "isolated-vm": "^6.1.2",
    "openai": "^6.16.0",
    "p-limit": "^5.0.0",
    "reflect-metadata": "^0.2.2",
    "request-filtering-agent": "^3.2.0",
    "tsup": "^8.5.1",
    "tweetnacl": "^1.0.3",
    "twitter-api-v2": "^1.24.0",
    "typescript": "5.8.2",
    "uuid": "^9.0.1",
    "ws": "^8.16.0",
    "x402check": "^0.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.15.3",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "concurrently": "^8.2.2",
    "eslint": "^9.31.0",
    "nodemon": "^3.0.2",
    "supertest": "^7.1.4",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript-eslint": "^8.59.3",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@10.6.5"
}
